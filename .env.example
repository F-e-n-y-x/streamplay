# ── StreamPlay configuration ─────────────────────────────────────────────────
# Copy this file to `.env` and fill in your values.

# Port the server listens on.
PORT=3000

# TMDB API key (v3 auth) — required for all metadata/browse/search.
# Get a free key at https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_here

# FlareSolverr instance used to bypass Cloudflare on scraping providers.
# In Docker Compose this points at the bundled flaresolverr service.
# Leave blank to fall back to the bundled Puppeteer-stealth solver (needs Chromium).
FLARESOLVERR_URL=http://flaresolverr:8191/

# Optional API key for WYZIE subtitles (free key at https://store.wyzie.io).
# Leave blank to disable the WyzieSubs provider.
WYZIE_KEY=

# Max time (ms) any single provider may take before the /api/streams route
# drops it and returns whatever the others produced.
PROVIDER_TIMEOUT_MS=45000
